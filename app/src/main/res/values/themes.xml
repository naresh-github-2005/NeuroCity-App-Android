<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme for Material 3 -->
    <style name="Base.Theme.NeuroCity" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
    </style>

    <!-- Base Material 3 Theme -->
    <style name="Theme.NeuroCity" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Material 3 Color System -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <item name="colorSecondary">@color/admin_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/admin_secondary</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Surface Colors -->
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="android:colorBackground">@color/background_light</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface_light</item>

        <!-- Text Appearance -->
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
        <item name="floatingActionButtonStyle">@style/Widget.App.FloatingActionButton</item>
    </style>

    <!-- Main Application Theme -->
    <style name="Theme.Neurocity" parent="Theme.NeuroCity">
        <!-- This inherits from the base theme -->
    </style>

    <!-- Enhanced Button Style -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="elevation">@dimen/elevation_sm</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Enhanced Card Style -->
    <style name="Widget.App.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="contentPadding">@dimen/card_padding</item>
        <item name="cardBackgroundColor">@color/cardBackgroundColor</item>
    </style>

    <!-- Enhanced Text Input Layout -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="boxStrokeColor">@color/input_box_stroke</item>
        <item name="hintTextColor">@color/input_hint</item>
        <item name="android:textColorHint">@color/text_secondary_light</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_icon_color</item>
        <item name="itemTextColor">@color/bottom_nav_text_color</item>
        <item name="itemRippleColor">@color/primary_light</item>
        <item name="elevation">@dimen/elevation_md</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.App.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="tint">@color/white</item>
        <item name="backgroundTint">@color/primary_color</item>
        <item name="elevation">@dimen/elevation_sm</item>
    </style>

    <!-- Toolbar/AppBar Style -->
    <style name="Widget.App.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="titleTextColor">@color/white</item>
        <item name="android:background">@color/primary_color</item>
        <item name="elevation">@dimen/elevation_sm</item>
    </style>

    <!-- Admin Dashboard Theme - Enhanced -->
    <style name="Theme.Neurocity.AdminDashboard" parent="Theme.NeuroCity">
        <!-- Material 3 Colors -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryContainer">@color/admin_primary</item>
        <item name="colorSecondary">@color/admin_secondary</item>

        <!-- Custom Attributes - Light Mode -->
        <item name="backgroundColor">@color/background_light</item>
        <item name="cardBackgroundColor">@color/surface_light</item>
        <item name="textPrimaryColor">@color/text_primary_light</item>
        <item name="textSecondaryColor">@color/text_secondary_light</item>

        <!-- Status bar color for admin -->
        <item name="android:statusBarColor">@color/primary_color</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.Neurocity.Splash" parent="Theme.NeuroCity">
        <item name="android:windowBackground">@drawable/gradient_overlay</item>
        <item name="android:statusBarColor">@color/primary_color</item>
    </style>

    <!-- Splash Screen Theme (alternative spelling) -->
    <style name="Theme.NeuroCity.Splash" parent="Theme.NeuroCity">
        <item name="android:windowBackground">@drawable/gradient_overlay</item>
        <item name="android:statusBarColor">@color/primary_color</item>
    </style>

</resources>