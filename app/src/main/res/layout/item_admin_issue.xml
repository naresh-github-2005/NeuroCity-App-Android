<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="@color/cardBackgroundColor"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 🖼️ Issue Image -->
        <ImageView
            android:id="@+id/imgIssue"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="@drawable/placeholder_bg"
            android:contentDescription="@string/issue_image_desc"
            android:adjustViewBounds="true"/>

        <!-- 📛 Issue Type -->
        <TextView
            android:id="@+id/txtIssueType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue Type"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/textColorPrimary"
            android:layout_marginTop="10dp"/>

        <!-- 📝 Issue Description -->
        <TextView
            android:id="@+id/txtIssueDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue description will appear here"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- 🏢 Department -->
        <TextView
            android:id="@+id/txtDept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dept: Water Supply"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="4dp"/>

        <!-- 👷 Assigned Worker -->
        <TextView
            android:id="@+id/txtAssigned"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Assigned to: -"
            android:textSize="14sp"
            android:textColor="@color/statusInProgress"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <!-- 🟢 Status -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textSize="14sp"
            android:textColor="@color/statusPending"
            android:layout_marginTop="4dp"/>

        <!-- ⏰ Reported Time -->
        <TextView
            android:id="@+id/txtReportedTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reported: -"
            android:textSize="13sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="4dp"/>

        <!-- ⚙️ Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <!-- First Row: View Map & Assign Worker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- View Map -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Map"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_location_pin"
                    app:iconPadding="6dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:backgroundTint="@color/mapButtonColor"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="8dp"/>

                <!-- Assign Worker -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAssignWorker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assign"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_worker"
                    app:iconPadding="6dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:backgroundTint="@color/statusInProgress"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

            <!-- Second Row: Update Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="8dp">

                <!-- Update Status -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_update"
                    app:iconPadding="6dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:backgroundTint="@color/admin_primary"
                    android:textColor="@android:color/white"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>