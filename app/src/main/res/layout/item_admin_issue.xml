<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/card_margin"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_sm"
    app:cardBackgroundColor="@color/cardBackgroundColor"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- 🖼️ Issue Image with Frame -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:id="@+id/imgIssue"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:background="@drawable/placeholder_bg"
                android:contentDescription="@string/issue_image_desc"
                android:adjustViewBounds="true"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- 📛 Issue Type -->
        <TextView
            android:id="@+id/txtIssueType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue Type"
            android:textStyle="bold"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/textColorPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <!-- 📝 Issue Description -->
        <TextView
            android:id="@+id/txtIssueDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue description will appear here"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/textColorSecondary"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="@dimen/spacing_md"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <!-- 🏢 Department -->
        <TextView
            android:id="@+id/txtDept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dept: Water Supply"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="@dimen/spacing_xs"/>

        <!-- 👷 Assigned Worker -->
        <TextView
            android:id="@+id/txtAssigned"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Assigned to: -"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold"
            android:textColor="@color/statusInProgress"
            android:layout_marginBottom="@dimen/spacing_xs"
            android:visibility="gone"/>

        <!-- 🟢 Status -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold"
            android:textColor="@color/statusPending"
            android:layout_marginBottom="@dimen/spacing_xs"/>

        <!-- ⏰ Reported Time -->
        <TextView
            android:id="@+id/txtReportedTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reported: -"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/textColorSecondary"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <!-- ⚙️ Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- First Row: View Map & Assign Worker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="@dimen/spacing_sm">

                <!-- View Map -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewMap"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_sm"
                    android:text="View Map"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_sm"
                    app:cornerRadius="@dimen/radius_full"
                    app:icon="@drawable/ic_location_pin"
                    app:iconPadding="@dimen/spacing_xs"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    app:backgroundTint="@color/mapButtonColor"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:stateListAnimator="@null"/>

                <!-- Assign Worker -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAssignWorker"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_sm"
                    android:text="Assign"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_sm"
                    app:cornerRadius="@dimen/radius_full"
                    app:icon="@drawable/ic_worker"
                    app:iconPadding="@dimen/spacing_xs"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    app:backgroundTint="@color/statusInProgress"
                    android:textColor="@android:color/white"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Second Row: Update Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Update Status -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_sm"
                    android:text="Status"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_update"
                    app:iconPadding="6dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:backgroundTint="@color/admin_primary"
                    android:textColor="@android:color/white"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>