<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Spacer for better vertical centering -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- App Logo for consistency -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/my_logo"
            android:contentDescription="App Logo"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:letterSpacing="0.02"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join NeuroCity today"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="40dp" />

        <!-- Email Input with Material Design -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/input_box_stroke"
            app:hintTextColor="@color/input_hint"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="?android:attr/textColorSecondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorTertiary"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input with Material Design -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/input_box_stroke"
            app:hintTextColor="@color/input_hint"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="?android:attr/textColorSecondary"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="?android:attr/textColorSecondary"
            app:helperText="At least 6 characters"
            app:helperTextTextColor="?android:attr/textColorSecondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorTertiary"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirm Password Input with Material Design -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/input_box_stroke"
            app:hintTextColor="@color/input_hint"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="?android:attr/textColorSecondary"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="?android:attr/textColorSecondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirm Password"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorTertiary"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/primary_color"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />


        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:text="Register"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:background="@drawable/button_gradient_primary"
            app:cornerRadius="@dimen/radius_md"
            android:letterSpacing="0.05"
            android:stateListAnimator="@null" />

        <!-- Divider with text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="?android:attr/textColorSecondary"
                android:alpha="0.3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="?android:attr/textColorSecondary"
                android:alpha="0.3" />
        </LinearLayout>

        <!-- Go to Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToLogin"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:text="Go to Login"
            android:textColor="@color/primary_color"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:backgroundTint="@color/secondary_button_bg"
            app:cornerRadius="@dimen/radius_md"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="2dp"
            android:letterSpacing="0.05"
            android:stateListAnimator="@null" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>