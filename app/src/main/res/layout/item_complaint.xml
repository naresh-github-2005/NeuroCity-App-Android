<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/card_margin"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_sm"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/cardBackgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image with rounded top corners -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            android:layout_margin="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivIssue"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    android:background="@color/dividerColor"
                    android:contentDescription="@string/issue_image_desc" />

                <!-- Gradient Overlay for better text visibility -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_overlay" />

                <!-- Status Badge Overlay -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm"
                    android:background="@drawable/status_badge_pending"
                    android:textColor="@android:color/white"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/spacing_md"
                    android:elevation="@dimen/elevation_sm"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Issue Type with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@drawable/ic_issue_type"
                    android:tint="@color/primary_color"
                    android:contentDescription="@string/issue_icon"/>

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Water Logging"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Severe water logging issue causing traffic disruption"
                android:textColor="@color/textColorSecondary"
                android:textSize="@dimen/text_sm"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_md"
                android:maxLines="3"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerColor"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"/>

            <!-- Info Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_md">

                <!-- Location Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@drawable/ic_location_pin"
                        android:tint="@color/textColorSecondary"
                        android:contentDescription="@string/location_icon"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Location"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/textColorSecondary"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Time Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@drawable/ic_time"
                        android:tint="@color/textColorSecondary"
                        android:contentDescription="@string/time_icon"/>

                    <TextView
                        android:id="@+id/tvTimestamp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2 hours ago"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/textColorSecondary"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Track Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrack"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_md"
                android:text="Track Issue Progress"
                android:textAllCaps="false"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                app:icon="@drawable/ic_track"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/spacing_md"
                app:iconSize="@dimen/icon_size_md"
                app:cornerRadius="@dimen/radius_md"
                android:background="@drawable/button_gradient_primary"
                android:textColor="@android:color/white"
                app:rippleColor="@android:color/white"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>