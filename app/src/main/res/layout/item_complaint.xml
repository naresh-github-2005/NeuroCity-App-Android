<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/cardBackgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image with rounded top corners -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_margin="0dp">

            <ImageView
                android:id="@+id/ivIssue"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:background="@color/dividerColor"
                android:contentDescription="@string/issue_image_desc" />

            <!-- Status Badge Overlay -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/status_badge_background"
                android:textColor="@android:color/white"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:elevation="4dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Issue Type with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_issue_type"
                    android:tint="@color/admin_primary"
                    android:contentDescription="@string/issue_icon"/>

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Water Logging"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_marginStart="12dp"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Severe water logging issue causing traffic disruption"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="12dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerColor"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Info Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Location Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_location_pin"
                        android:tint="@color/textColorSecondary"
                        android:contentDescription="@string/location_icon"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Location"
                        android:textSize="12sp"
                        android:textColor="@color/textColorSecondary"
                        android:layout_marginStart="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Time Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_time"
                        android:tint="@color/textColorSecondary"
                        android:contentDescription="@string/time_icon"/>

                    <TextView
                        android:id="@+id/tvTimestamp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2 hours ago"
                        android:textSize="12sp"
                        android:textColor="@color/textColorSecondary"
                        android:layout_marginStart="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Track Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Track Issue Progress"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_track"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="22dp"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/admin_primary"
                android:textColor="@android:color/white"
                app:elevation="3dp"
                android:layout_marginTop="16dp"
                app:rippleColor="@android:color/white"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>