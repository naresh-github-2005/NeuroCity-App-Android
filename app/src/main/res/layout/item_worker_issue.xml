<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="@color/cardBackgroundColor"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 🖼️ Issue Image -->
        <ImageView
            android:id="@+id/issueImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="@drawable/placeholder_bg"
            android:contentDescription="Issue Image"
            android:adjustViewBounds="true"/>

        <!-- Label for showing if it's resolved image or original -->
        <TextView
            android:id="@+id/imageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original Image"
            android:textSize="12sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="4dp" />

        <!-- 📛 Issue Type -->
        <TextView
            android:id="@+id/issueType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue Type"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/textColorPrimary"
            android:layout_marginTop="10dp"/>

        <!-- 📝 Issue Description -->
        <TextView
            android:id="@+id/issueDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue description"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="6dp"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- 🟢 Status & Time -->
        <TextView
            android:id="@+id/issueStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textSize="14sp"
            android:textColor="@color/statusPending"
            android:layout_marginTop="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUploadResolvedImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Resolved Image"
            android:layout_marginTop="8dp"
            android:icon="@drawable/ic_upload" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
